---
layout: default
---
{% comment %}
  Local override of al_folio_core's about.liquid:
  the social icons + contact note are moved from the page bottom into the
  profile card, directly under the photo / more_info.
{% endcomment %}
<style>
  .profile-social {
    margin-top: 0.6rem;
  }
  .profile-social .contact-icons {
    font-size: 1.6rem;
    line-height: 2.4rem;
    text-align: center;
  }
  .profile-social .contact-icons a {
    padding: 0 0.25rem;
  }
  .profile-social .contact-note {
    font-size: 0.75rem;
    text-align: center;
    margin-top: 0.15rem;
  }
</style>
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
        {% if page.social %}
          <div class="social profile-social">
            <div class="contact-icons">{% social_links %}</div>

            <div class="contact-note">{{ site.contact_note }}</div>
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News (local override: show the latest N with a show-more expander) -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      <div class="news">
        {% if site.news != blank %}
          {% assign news = site.news | reverse %}
          {% assign news_size = site.news | size %}
          {% assign visible_count = page.announcements.limit | default: 5 %}
          <div class="table-responsive">
            <table class="table table-sm table-borderless">
              {% for item in news limit: visible_count %}
                <tr>
                  <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
                  <td>
                    {% if item.inline %}
                      {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                    {% else %}
                      <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </table>
            {% if news_size > visible_count %}
              <div id="news-more" style="display: none">
                <table class="table table-sm table-borderless">
                  {% for item in news offset: visible_count %}
                    <tr>
                      <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
                      <td>
                        {% if item.inline %}
                          {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                        {% else %}
                          <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                        {% endif %}
                      </td>
                    </tr>
                  {% endfor %}
                </table>
              </div>
              <button id="news-toggle" class="btn btn-sm z-depth-0" type="button" onclick="toggleNews()">show more</button>
              <script>
                function toggleNews() {
                  var more = document.getElementById('news-more');
                  var btn = document.getElementById('news-toggle');
                  var open = more.style.display !== 'none';
                  more.style.display = open ? 'none' : 'block';
                  btn.textContent = open ? 'show more' : 'show less';
                }
              </script>
            {% endif %}
          </div>
        {% else %}
          <p>No news so far...</p>
        {% endif %}
      </div>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% if site.plugins contains 'al_newsletter' %}
        {% include plugins/al_newsletter_form_center_margin.liquid %}
      {% else %}
        {% include newsletter.liquid center=true %}
      {% endif %}
    {% endif %}
  </article>
</div>
